{
  "name": "@pdfmuse/node",
  "version": "0.1.8",
  "description": "Deterministic PDF/DOCX parser for RAG / LLMs \u2014 native Node.js binding.",
  "license": "MIT OR Apache-2.0",
  "repository": "https://github.com/casperkwok/pdfmuse",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "native.js",
    "native.d.ts"
  ],
  "napi": {
    "name": "native",
    "binaryName": "native",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2",
    "@types/node": "^20",
    "typescript": "^5"
  },
  "scripts": {
    "build:native": "napi build --platform --release --cargo-cwd ../../crates/pdfmuse-node --js native.js --dts native.d.ts",
    "build": "npm run build:native && tsc"
  },
  "keywords": [
    "pdf",
    "docx",
    "parser",
    "rag",
    "llm",
    "text-extraction",
    "ocr",
    "pymupdf",
    "document"
  ]
}
